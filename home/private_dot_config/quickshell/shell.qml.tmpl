          "check(){ f=\"$1\"; mode=\"$2\"; [ -f \"$f\" ] || return; tgt=$(head -n1 \"$f\" 2>/dev/null || true); " +
          "if [ -z \"$tgt\" ] || [ \"$tgt\" = \"any\" ] || [ \"$tgt\" = \"$mon\" ]; then rm -f \"$f\"; r=\"${r}${mode}\\n\"; fi; }; " +
