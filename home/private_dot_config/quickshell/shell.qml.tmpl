      property var memoJaxQueue: []
      property string memoJaxActiveSrc: "input"

      function memoSendToJax(text, src) {
        memoJaxQueue.push({ text: text, src: src || "input" })
        memoSendToJaxNext()
      }

      function memoSendToJaxNext() {
        if (memoJaxSendProc.running || memoJaxQueue.length === 0)
          return
        var item = memoJaxQueue.shift()
        memoJaxActiveSrc = item.src || "input"
        var textB64 = Qt.btoa(item.text || "")
        memoJaxSendProc.command = ["/usr/bin/env", "bash", "-lc",
          "txt=$(printf '%s' \"$1\" | base64 -d); " +
          "if ! command -v jax-pad &>/dev/null; then printf 'MISSING\\n'; exit 0; fi; " +
          "if out=$(jax-pad note \"$txt\" 2>&1); then printf 'OK\\n%s\\n' \"$out\"; else printf 'ERR\\n%s\\n' \"$out\"; fi",
          "_", textB64]
        memoJaxSendProc.running = true
      }

      function memoSave(text, src) {
        memoSendToJax(text, src || "input")
      }

      Process {
        id: memoJaxSendProc
        running: false
        stdout: StdioCollector {
          onStreamFinished: {
            var out = root.trim(this.text)
            var status = ""
            if (out.length > 0)
              status = root.trim(out.split("\n")[0])
            if (status === "OK") {
              memoCountProc.running = true
              if (memoInput.visible)
                memoInput.refresh()
              if (memoReview.visible)
                memoReview.refresh()
              if (panel.memoJaxActiveSrc === "clipboard")
                root.runShell("notify-send -r 91192 -t 2000 'Quick Memo' 'Clipboard saved to jax-pad'")
            } else if (status === "MISSING") {
              root.runShell("notify-send -r 91192 -t 3000 -u critical 'Quick Memo' 'jax-pad CLI not found'")
            } else {
              root.runShell("notify-send -r 91192 -t 3000 -u critical 'Quick Memo' 'Failed to send to jax-pad'")
