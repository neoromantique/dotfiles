# Hypridle Configuration
# Device: {{ .deviceProfile }} ({{ .hostname }})
# Idle timeout: {{ .idleTimeout }} seconds

general {
    lock_cmd = hyprctl switchxkblayout all 0; pidof hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session
{{- if .hasMultipleMonitors }}
    after_sleep_cmd = hyprctl dispatch dpms on; sleep 1; hyprctl keyword monitor {{ .secondaryMonitor }},{{ .secondaryResolution }},0x-992,1,transform,1 && hyprctl keyword monitor {{ .primaryMonitor }},{{ .primaryResolution }},1440x0,1
{{- else }}
    after_sleep_cmd = hyprctl dispatch dpms on; sleep 1; hyprctl keyword monitor {{ .primaryMonitor }},{{ .primaryResolution }},auto,1
{{- end }}
}

listener {
    timeout = {{ .idleTimeout }}
    on-timeout = hyprctl dispatch dpms off
{{- if .hasMultipleMonitors }}
    on-resume = hyprctl dispatch dpms on; sleep 1; hyprctl keyword monitor {{ .secondaryMonitor }},{{ .secondaryResolution }},0x-992,1,transform,1 && hyprctl keyword monitor {{ .primaryMonitor }},{{ .primaryResolution }},1440x0,1
{{- else }}
    on-resume = hyprctl dispatch dpms on; sleep 1; hyprctl keyword monitor {{ .primaryMonitor }},{{ .primaryResolution }},auto,1
{{- end }}
}

{{- if .hasBattery }}
# Laptop: dim screen before turning off
listener {
    timeout = {{ sub .idleTimeout 60 }}
    on-timeout = brightnessctl -s set 30%
    on-resume = brightnessctl -r
}

# Laptop: suspend after extended idle
listener {
    timeout = {{ mul .idleTimeout 2 }}
    on-timeout = systemctl suspend
}
{{- end }}
